APP_NAME=AI SQL Analyst Agent
APP_DATA_DIR=./data
APP_SCHEMA_SAMPLE_ROWS=5
APP_MAX_UPLOAD_SIZE_MB=25
APP_MAX_QUERY_ROWS=1000
APP_SQL_CORRECTION_ATTEMPTS=1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Local default. For deployment, set this to the Streamlit app URL.
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Frontend only. For Docker Compose this points to the backend service name.
API_BASE_URL=http://localhost:8000
